" =============================================================================
" .ideavimrc — mirrors ~/.config/nvim (single source of truth)
"
" Convention: when a binding diverges between nvim and IdeaVim, nvim wins.
" Pure-IDE conveniences that have no nvim counterpart live in clearly-marked
" "IDE-only" sections so they never collide with nvim bindings.
"
" Matching nvim layout:
"   nvim/lua/smallzoodev/core/options.lua       -> Section: OPTIONS
"   nvim/lua/smallzoodev/core/keymaps.lua       -> Section: CORE KEYMAPS
"   nvim/lua/smallzoodev/plugins/*.lua          -> Section: PLUGIN PARITY
" =============================================================================

" =============================================================================
" OPTIONS  (mirrors nvim/core/options.lua + sane IdeaVim defaults)
" =============================================================================

set number
set relativenumber
set tabstop=2
set shiftwidth=2
set expandtab
set autoindent

set nowrap
set ignorecase
set smartcase
set hlsearch
set incsearch

set cursorline
set scrolloff=8
set sidescrolloff=8

set clipboard+=unnamedplus
set clipboard+=unnamed

set splitright
set splitbelow

set history=1000
set undolevels=2000
set matchpairs
set nrformats
set visualbell

set timeoutlen=500

" --- IdeaVim-specific
set ideajoin
set ideamarks
set ideastatusicon=gray
set idearefactormode=keep
" set trackactionids        " uncomment when discovering action IDs

" =============================================================================
" PLUGINS  (emulated; nvim plugin equivalents shown in comments)
" =============================================================================

" tpope/vim-surround                — replaces nvim mini.surround (sa/sd/sr aliases below)
Plug 'tpope/vim-surround'
set surround

" tpope/vim-commentary              — replaces nvim mini.comment (gcc, gc{motion})
Plug 'tpope/vim-commentary'
set commentary

" easymotion/vim-easymotion         — replaces nvim flash.nvim (s-prefix jumps)
" Requires JetBrains plugins: AceJump + IdeaVim-EasyMotion
Plug 'easymotion/vim-easymotion'
set easymotion

" machakann/vim-highlightedyank     — replaces visual feedback for yanks
Plug 'machakann/vim-highlightedyank'
set highlightedyank

" vim-scripts/argtextobj.vim        — replaces nvim treesitter @parameter (aa/ia)
Plug 'vim-scripts/argtextobj.vim'
set argtextobj

" kana/vim-textobj-entire           — handy for whole-buffer ops
Plug 'kana/vim-textobj-entire'
set textobj-entire

" Function text-object              — replaces nvim treesitter @function (af/if)
" Requires JetBrains plugin: IdeaVim FunctionTextObj
set functiontextobj

" Mini.ai                           — replaces nvim mini.ai text-objects
set mini-ai

" preservim/nerdtree                — kept for users who prefer NERDTree to ProjectView
Plug 'preservim/nerdtree'
set NERDTree

" Which-Key                         — replaces nvim folke/which-key.nvim
" Requires JetBrains plugin: Which-Key
set which-key

let mapleader=" "

" =============================================================================
" EASYMOTION CONFIG  (nvim flash.nvim parity for s-prefix jumps)
" =============================================================================

let g:EasyMotion_do_mapping = 0
let g:EasyMotion_smartcase = 1

nmap sf <Plug>(easymotion-f)
nmap sF <Plug>(easymotion-F)
nmap sj <Plug>(easymotion-j)
nmap sk <Plug>(easymotion-k)
nmap sw <Plug>(easymotion-w)
nmap sb <Plug>(easymotion-b)

" =============================================================================
" CORE KEYMAPS  (mirrors nvim/core/keymaps.lua)
" =============================================================================

" Insert-mode escape
inoremap jk <Esc>

" Increment / decrement number
nnoremap <leader>+ <C-a>
nnoremap <leader>- <C-x>

" Window splits (matches nvim <leader>w group)
nmap <leader>wv <Action>(SplitVertically)
nmap <leader>ws <Action>(SplitHorizontally)
nmap <leader>we <C-w>=
nmap <leader>wx <Action>(Unsplit)

" Buffer / tab navigation (nvim: <Tab>=bnext, <S-Tab>=bprev)
nmap <Tab>     <Action>(NextTab)
nmap <S-Tab>   <Action>(PreviousTab)

" Visual indent keeps selection
xnoremap < <gv
xnoremap > >gv

" Display-line j/k when no count (nvim parity)
nnoremap <expr> j v:count == 0 ? 'gj' : 'j'
nnoremap <expr> k v:count == 0 ? 'gk' : 'k'
xnoremap <expr> j v:count == 0 ? 'gj' : 'j'
xnoremap <expr> k v:count == 0 ? 'gk' : 'k'

" Resize splits (nvim parity)
nnoremap <C-Up>    <Action>(StretchSplitToTop)
nnoremap <C-Down>  <Action>(StretchSplitToBottom)
nnoremap <C-Left>  <Action>(StretchSplitToLeft)
nnoremap <C-Right> <Action>(StretchSplitToRight)

" Esc clears hlsearch (nvim parity)
nnoremap <Esc> :nohlsearch<CR>

" Visual paste without yanking
xnoremap p "_dP

" yp / gp — copy filepath:line and go to file:line
nmap yp <Action>(CopyPathWithLineNumber)
nmap gp <Action>(GotoFile)

" Helix-style line motions
nnoremap gh 0
nnoremap gl $
nnoremap gs ^
xnoremap gh 0
xnoremap gl $
xnoremap gs ^

" U → redo  (nvim parity)
nnoremap U <Action>(Redo)

" <C-r> → reload from disk  (closest to nvim's checktime + LSP restart)
nnoremap <C-r> <Action>(Synchronize)

" Toggle word-wrap
nmap <leader>uw <Action>(EditorToggleUseSoftWraps)

" Disable F1 help (nvim parity)
nmap <F1> <Nop>
xmap <F1> <Nop>
inoremap <F1> !

" =============================================================================
" CMD-LINE TYPO ALIASES  (nvim parity: W, Q, Wq, Qa, ...)
" =============================================================================

command! -bang W   write<bang>
command! -bang Q   quit<bang>
command! -bang Wq  wq<bang>
command! -bang WQ  wq<bang>
command! -bang Wa  wall<bang>
command! -bang WA  wall<bang>
command! -bang Qa  qall<bang>
command! -bang QA  qall<bang>
command! -bang Wqa wqa<bang>
command! -bang WQa wqa<bang>
command! -bang WQA wqa<bang>
command! -bang Xa  xall<bang>
command! -bang XA  xall<bang>

" =============================================================================
" MINI.MOVE PARITY  (move lines/selection)
" =============================================================================

" Normal mode: move current line/element
nmap J       <Action>(MoveStatementDown)
nmap K       <Action>(MoveStatementUp)
nmap <S-h>   <Action>(MoveElementLeft)
nmap <S-l>   <Action>(MoveElementRight)

" Visual mode: move selection
xmap J       <Action>(MoveStatementDown)
xmap K       <Action>(MoveStatementUp)
xmap <S-h>   <Action>(MoveElementLeft)
xmap <S-l>   <Action>(MoveElementRight)

" =============================================================================
" MINI.SURROUND ALIASES  (nvim mini.surround used sa/sd/sh/sr/sn)
" Built on top of vim-surround. `s` is no longer NOPed — surround owns it.
" =============================================================================

nmap sa  ys
nmap saa yss
xmap sa  S
nmap sd  ds
nmap sr  cs

" =============================================================================
" TREESITTER INCREMENTAL SELECTION PARITY
"   nvim: <CR> init / expand, <BS> shrink
" =============================================================================

nmap <CR> <Action>(EditorSelectWord)
xmap <CR> <Action>(EditorSelectWord)
xmap <BS> <Action>(EditorUnSelectWord)

" =============================================================================
" LSP-LIKE NAV  (mirrors nvim lspconfig keymaps)
" =============================================================================

nmap gd <Action>(GotoDeclaration)
nmap gD <Action>(GotoTypeDeclaration)
nmap gR <Action>(FindUsages)
nmap gi <Action>(GotoImplementation)
nmap gt <Action>(GotoTypeDeclaration)
nmap gI <Action>(GotoSuperMethod)
nmap gu <Action>(ShowUsages)

" Code intelligence (single-key leader)
nmap <leader>a <Action>(ShowIntentionActions)
xmap <leader>a <Action>(ShowIntentionActions)
nmap <leader>r <Action>(RenameElement)
nmap <leader>k <Action>(QuickJavaDoc)

" Diagnostics navigation (nvim: [d/]d)
nmap [d <Action>(GotoPreviousError)
nmap ]d <Action>(GotoNextError)

" Hunk / change navigation (nvim gitsigns: [[/]])
nmap [[ <Action>(VcsShowPrevChangeMarker)
nmap ]] <Action>(VcsShowNextChangeMarker)

" Function navigation (nvim treesitter: [m/]m)
nmap [m <Action>(MethodUp)
nmap ]m <Action>(MethodDown)
omap [m :action MethodUp<CR>
omap ]m :action MethodDown<CR>

" Reference navigation under caret (nvim snacks: ]h/[h)
nmap ]h <Action>(GotoNextElementUnderCaretUsage)
nmap [h <Action>(GotoPrevElementUnderCaretUsage)

" Git change history (vim-builtin parity)
nmap g; <Action>(JumpToLastChange)
nmap g, <Action>(JumpToNextChange)

" =============================================================================
" PICKERS / FZF-LUA PARITY
" =============================================================================

nmap <leader>/  <Action>(FindInPath)
nmap <leader>?  <Action>(GotoAction)
nmap <leader>'  <Action>(RecentFiles)

" <leader>f group (Find)
nmap <leader>ff <Action>(GotoFile)
nmap <leader>fF <Action>(GotoFile)
nmap <leader>fd <Action>(ActivateProblemsViewToolWindow)
nmap <leader>fD <Action>(ActivateProblemsViewToolWindow)

" Buffers / structure / symbols
nmap <leader>b  <Action>(Switcher)
nmap <leader>B  <Action>(CloseContent)
nmap <leader>s  <Action>(FileStructurePopup)
nmap <leader>S  <Action>(GotoSymbol)

" Project view explorer (nvim neo-tree parity)
nmap <leader>e  <Action>(ActivateProjectToolWindow)
nmap <leader>E  <Action>(SelectInProjectView)

" =============================================================================
" <leader>g  — GIT  (nvim gitsigns + snacks.gitbrowse)
" =============================================================================

nmap <leader>gs  <Action>(Git.Stage)
nmap <leader>gr  <Action>(Vcs.RollbackChangedLines)
xmap <leader>gs  <Action>(Git.Stage)
xmap <leader>gr  <Action>(Vcs.RollbackChangedLines)
nmap <leader>gS  <Action>(ChangesView.AddUnversioned)
nmap <leader>gR  <Action>(ChangesView.Revert)
nmap <leader>gu  <Action>(Vcs.RollbackChangedLines)
nmap <leader>gp  <Action>(VcsShowCurrentChangeMarker)
nmap <leader>gb  <Action>(Annotate)
nmap <leader>gB  <Action>(Annotate)
nmap <leader>gd  <Action>(Compare.SameVersion)
nmap <leader>gD  <Action>(Vcs.ShowDiffWithLocal)
nmap <leader>gO  <Action>(Github.Open.In.Browser.From.Editor)

" Extras (no nvim equivalent — kept because they don't conflict with the group)
nmap <leader>gv  <Action>(Git.Branches)
nmap <leader>gh  <Action>(Vcs.ShowTabbedFileHistory)
nmap <leader>gc  <Action>(ActivateCommitToolWindow)

" =============================================================================
" <leader>x  — TROUBLE / DIAGNOSTICS  (nvim trouble.nvim)
" =============================================================================

nmap <leader>xw <Action>(ActivateProblemsViewToolWindow)
nmap <leader>xd <Action>(ActivateProblemsViewToolWindow)
nmap <leader>xq <Action>(ActivateMessagesToolWindow)
nmap <leader>xl <Action>(ActivateMessagesToolWindow)
nmap <leader>xt <Action>(ActivateTODOToolWindow)

" =============================================================================
" <leader>d  — DEBUG  (nvim DAP parity)
" =============================================================================

nmap <leader>dc <Action>(Resume)
nmap <leader>dg <Action>(RunToCursor)
nmap <leader>db <Action>(ToggleLineBreakpoint)
nmap <leader>dB <Action>(EditBreakpoint)
nmap <leader>di <Action>(StepInto)
nmap <leader>do <Action>(StepOver)
nmap <leader>dO <Action>(StepOut)
nmap <leader>dt <Action>(Stop)
nmap <leader>du <Action>(ActivateDebugToolWindow)
nmap <leader>de <Action>(QuickEvaluateExpression)
xmap <leader>de <Action>(EvaluateExpression)
nmap <leader>dr <Action>(JShell.Console)
nmap <leader>dl <Action>(Debug)

" =============================================================================
" <leader>n / <leader>p  — TREESITTER SWAPS  (nvim swap.next/prev)
" =============================================================================

nmap <leader>na <Action>(MoveElementRight)
nmap <leader>nm <Action>(MoveStatementDown)
nmap <leader>n: <Action>(MoveElementRight)
nmap <leader>pa <Action>(MoveElementLeft)
nmap <leader>pm <Action>(MoveStatementUp)
nmap <leader>p: <Action>(MoveElementLeft)

" =============================================================================
" <leader>m  — FORMAT  (nvim conform.nvim)
" =============================================================================

nmap <leader>mp <Action>(ReformatCode)
xmap <leader>mp <Action>(ReformatCode)

" =============================================================================
" <leader>l  — LSP-LIKE  (nvim lspconfig group)
" =============================================================================

nmap <leader>ld <Action>(ShowErrorDescription)
nmap <leader>lh <Action>(ToggleInlayHintsGloballyAction)
nmap <leader>li <Action>(ShowSettings)
nmap <leader>lc <Action>(RunInspection)
nmap <leader>lC <Action>(CodeCleanup)
nmap <leader>ll <Action>(ShowLog)
nmap <leader>lR :source ~/.ideavimrc<CR>

" =============================================================================
" <leader>u  — UI  (nvim toggles + snacks notifications)
" =============================================================================

nmap <leader>un <Action>(ClearAllNotifications)
nmap <leader>uh <Action>(ActivateNotificationsToolWindow)
" <leader>uw is defined above (toggle wrap)

" =============================================================================
" <leader>o  — OUTLINE  (nvim aerial.nvim parity)
" =============================================================================

nmap <leader>o <Action>(ActivateStructureToolWindow)
nmap ]a        <Action>(MethodDown)
nmap [a        <Action>(MethodUp)

" =============================================================================
" <leader>O  — OBSIDIAN
" No IDEA equivalent for obsidian.nvim; intentionally left as a free prefix.
" =============================================================================

" =============================================================================
" OUTLINE / OUTLINE-LIKE  — outer text objects
" Note: nvim treesitter textobjects @class/@conditional/@loop/@call have no
" direct IdeaVim emulation. argtextobj covers @parameter; functiontextobj
" covers @function (af/if). The remaining ones fall back to vim builtins.
" =============================================================================

" =============================================================================
" WINDOW NAVIGATION  (nvim vim-tmux-navigator parity)
" =============================================================================

nmap <C-h> <C-w>h
nmap <C-j> <C-w>j
nmap <C-k> <C-w>k
nmap <C-l> <C-w>l

" =============================================================================
" IDE-ONLY CONVENIENCES  (no nvim equivalent — kept because they don't conflict)
" =============================================================================

" Cmd-line shortcut
nnoremap <C-m> :
xnoremap <C-m> :
inoremap <C-m> <CR>
cnoremap <C-m> <CR>

" Insert-mode helpers (emacs-ish line nav)
inoremap <C-e> <C-o>A
inoremap <C-s> <C-o>I
inoremap <C-f> <Esc>:let @z=@/<CR>/\v[)"}>]<CR>:let @/=@z<CR>:noh<CR>a
inoremap <C-b> <Esc>:let @z=@/<CR>?\v[("{<]<CR>:let @/=@z<CR>:noh<CR>i

" Tab management (close-other / left / right)
nmap <leader>too <Action>(CloseAllEditorsButActive)
nmap <leader>tol <Action>(CloseAllToTheLeft)
nmap <leader>tor <Action>(CloseAllToTheRight)

" PageUp / PageDown as redundant tab nav
nmap <PageDown> <Action>(NextTab)
nmap <PageUp>   <Action>(PreviousTab)

" Refactor / quick-fix (moved off the old <Tab>-prefix because <Tab>=NextTab now)
nmap <leader>cr <Action>(Refactorings.QuickListPopupAction)
nmap <leader>cv <Action>(IntroduceVariable)
nmap <leader>cf <Action>(QuickFixes)
nmap <leader>cy <Action>(CopyReferencePopupGroup)

" =============================================================================
" TOOL WINDOWS  (F1 prefix — IDE-only, no nvim equivalent)
" =============================================================================

nmap <F1>s <Action>(ActivateStructureToolWindow)
nmap <F1>d <Action>(ActivateDatabaseToolWindow)
nmap <F1>t <Action>(ActivateTerminalToolWindow)
nmap <F1>b <Action>(ShowBookmarks)
nmap <F1>p <Action>(ActivateProblemsViewToolWindow)
nmap <F1>c <Action>(ActivateCommitToolWindow)
nmap <F1>f <Action>(ActivateFindToolWindow)
nmap <F1>r <Action>(ActivateRunToolWindow)

" =============================================================================
" BOOKMARKS  (numbered) — IDE-only convenience
"   goto:    `0..`9   (backtick — no conflict with marks since digits aren't mark names)
"   toggle:  <F2>0..<F2>9   (moved off <leader>m, which is now Format)
" =============================================================================

nmap `0 <Action>(GotoBookmark0)
nmap `1 <Action>(GotoBookmark1)
nmap `2 <Action>(GotoBookmark2)
nmap `3 <Action>(GotoBookmark3)
nmap `4 <Action>(GotoBookmark4)
nmap `5 <Action>(GotoBookmark5)
nmap `6 <Action>(GotoBookmark6)
nmap `7 <Action>(GotoBookmark7)
nmap `8 <Action>(GotoBookmark8)
nmap `9 <Action>(GotoBookmark9)

nmap <F2>0 <Action>(ToggleBookmark0)
nmap <F2>1 <Action>(ToggleBookmark1)
nmap <F2>2 <Action>(ToggleBookmark2)
nmap <F2>3 <Action>(ToggleBookmark3)
nmap <F2>4 <Action>(ToggleBookmark4)
nmap <F2>5 <Action>(ToggleBookmark5)
nmap <F2>6 <Action>(ToggleBookmark6)
nmap <F2>7 <Action>(ToggleBookmark7)
nmap <F2>8 <Action>(ToggleBookmark8)
nmap <F2>9 <Action>(ToggleBookmark9)

" =============================================================================
" RELOAD CONFIG
" =============================================================================

nnoremap <F10><F10> :source ~/.ideavimrc<CR>
